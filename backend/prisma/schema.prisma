generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("USER")
  character Character?
}

model Character {
  id        Int      @id @default(autoincrement())
  name      String
  level     Int      @default(1)
  hp        Int      @default(100)
  experience Int     @default(0)

  //Stacks de combate

  attack    Int @default(10)
  defense   Int @default(5)
  luck      Int @default(5)
  critChance  Float @default(0.05)
  critDamage  Float @default(1.1)

  totalDamageDone Int      @default(0)

  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  inventory Item[]
}

enum MonsterType {
  BASIC
  ELITE
  BOSS
}

model Monster {
  id        Int           @id @default(autoincrement())
  name      String   
  type      MonsterType   @default(BASIC)      //Slime, Goblin, ETC...
  hp        Int           @default(50)
  attack    Int           @default(10)
 // expYield  Int         @default(20)
}

enum ItemType {
  WEAPON
  CONSUMABLE
  ARMOR
  KEYS
}

model Item {
  id          Int       @id @default(autoincrement())
  name        String
  type        ItemType    
  value       Int       @default(0)
  // Stacks que otorga cada item

  bonusHp     Int @default(0)
  bonusAtack    Int @default(0)
  bonusCrit     Float @default(0)
  bonusLuck     Int @default(0)


  characterId Int
  character   Character @relation(fields: [characterId], references: [id])
}

model GameLog {
  id        Int      @id @default(autoincrement())
  event     String
  createdAt DateTime @default(now())
}