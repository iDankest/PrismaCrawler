generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("USER")
  character Character?
}

model Character {
  id        Int      @id @default(autoincrement())
  name      String
  level     Int      @default(1)
  hp        Int      @default(100)
  experience Int     @default(0)
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  inventory Item[]
}

model Monster {
  id          Int
  monsterId   Int
}

model Item {
  id          Int       @id @default(autoincrement())
  name        String
  type        String    
  value       Int       @default(0)
  characterId Int
  character   Character @relation(fields: [characterId], references: [id])
}

model GameLog {
  id        Int           @id @default(autoincrement())
  characterId Int
  character Character     @relation(fields: [characterId], references: [id])

  eventType GameEventType
  details   String        // JSON serializado
  createdAt DateTime      @default(now())
}

// FALTA: Modelo Dungeon (estado actual del juego)
model Dungeon {
  id        Int      @id @default(autoincrement())
  characterId Int
  character Character @relation(fields: [characterId], references: [id])

  // Estado del dungeon
  tiles     DungeonTile[]
  enemies   DungeonEnemy[]
  items     DungeonItem[]

  // Posición del jugador
  playerX   Int
  playerY   Int

  // Metadata
  level     Int      @default(1)
  createdAt DateTime @default(now())
  savedAt   DateTime @updatedAt
}

// FALTA: Tiles del dungeon
model DungeonTile {
  id        Int      @id @default(autoincrement())
  dungeonId Int
  dungeon   Dungeon  @relation(fields: [dungeonId], references: [id])

  x         Int
  y         Int
  type      TileType // FLOOR, WALL, DOOR, etc
}

enum TileType {
  FLOOR
  WALL
  DOOR
  LOOT
}

// FALTA: Enemies en el dungeon (son instancias, no globales)
model DungeonEnemy {
  id        Int      @id @default(autoincrement())
  dungeonId Int
  dungeon   Dungeon  @relation(fields: [dungeonId], references: [id])

  monsterId Int
  monster   Monster  @relation(fields: [monsterId], references: [id])

  x         Int
  y         Int
  currentHp Int
}

// Items en el dungeon
model DungeonItem {
  id        Int      @id @default(autoincrement())
  dungeonId Int
  dungeon   Dungeon  @relation(fields: [dungeonId], references: [id])

  itemId    Int
  item      Item     @relation(fields: [itemId], references: [id])

  x         Int
  y         Int
}

// MEJOR: GameLog más específico
enum GameEventType {
  PLAYER_MOVED
  PLAYER_ATTACKED
  PLAYER_DIED
  ENEMY_DIED
  ITEM_PICKED
  LEVEL_UP
}
