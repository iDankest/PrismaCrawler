// .prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // <-- AÑADE ESTA LÍNEA
}

// 1. USUARIOS (Login y Registro)
model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  name     String
  role     String?  @default("USER")
  
  // Relación: Un usuario puede tener muchas puntuaciones guardadas
  scores   Score[]
}

// 2. MAPAS (El diseño de los niveles que leerá el frontend)
model Map {
  id         Int      @id @default(autoincrement())
  name       String   // Ej: "Mazmorra de Inicio"
  level      Int      @default(1)
  
  // Usamos el tipo Json de Prisma para guardar tu matriz ["####", "#_M_", ...]
  layout     Json     
  
  // Usamos Json para guardar qué hace cada letra { "M": { "hp": 30 } }
  dictionary Json     
  
  createdAt  DateTime @default(now())
}

// 3. PUNTUACIONES (Para el Top 10)
model Score {
  id        Int      @id @default(autoincrement())
  xp        Int      // La experiencia con la que murió el personaje
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
}