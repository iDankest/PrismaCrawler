// .prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // <-- AÑADE ESTA LÍNEA
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  role      String     @default("USER")
  character Character?
}

model Character {
  id         Int       @id @default(autoincrement())
  name       String
  level      Int       @default(1)
  hp         Int       @default(100)
  experience Int       @default(0)
  userId     Int       @unique
  user       User      @relation(fields: [userId], references: [id])
  
  // AÑADIDO: Relaciones inversas requeridas por Prisma
  inventory Item[]
  gameLogs  GameLog[]
  dungeons  Dungeon[]
}

model Monster {
  id             Int            @id @default(autoincrement()) // AÑADIDO: Faltaba el @id
  name           String         @default("Slime")             // AÑADIDO: Un nombre básico
  dungeonEnemies DungeonEnemy[]                               // AÑADIDO: Relación inversa
}

model Item {
  id           Int           @id @default(autoincrement())
  name         String
  type         String    
  value        Int           @default(0)
  
  // AÑADIDO: characterId debe ser opcional (Int?). 
  // Si un item está tirado en el Dungeon, aún no tiene dueño.
  characterId  Int?          
  character    Character?    @relation(fields: [characterId], references: [id])
  dungeonItems DungeonItem[] // AÑADIDO: Relación inversa
}

model GameLog {
  id          Int           @id @default(autoincrement())
  characterId Int
  character   Character     @relation(fields: [characterId], references: [id])
  eventType   GameEventType
  details     String        // JSON serializado
  createdAt   DateTime      @default(now())
}

model Dungeon {
  id          Int           @id @default(autoincrement())
  characterId Int
  character   Character     @relation(fields: [characterId], references: [id])

  tiles       DungeonTile[]
  enemies     DungeonEnemy[]
  items       DungeonItem[]

  playerX     Int
  playerY     Int

  level       Int           @default(1)
  createdAt   DateTime      @default(now())
  savedAt     DateTime      @updatedAt
}

model DungeonTile {
  id        Int      @id @default(autoincrement())
  dungeonId Int
  dungeon   Dungeon  @relation(fields: [dungeonId], references: [id])
  x         Int
  y         Int
  type      TileType
}

enum TileType {
  FLOOR
  WALL
  DOOR
  LOOT
}

model DungeonEnemy {
  id        Int      @id @default(autoincrement())
  dungeonId Int
  dungeon   Dungeon  @relation(fields: [dungeonId], references: [id])
  monsterId Int
  monster   Monster  @relation(fields: [monsterId], references: [id])
  x         Int
  y         Int
  currentHp Int
}

model DungeonItem {
  id        Int      @id @default(autoincrement())
  dungeonId Int
  dungeon   Dungeon  @relation(fields: [dungeonId], references: [id])
  itemId    Int
  item      Item     @relation(fields: [itemId], references: [id])
  x         Int
  y         Int
}

enum GameEventType {
  PLAYER_MOVED
  PLAYER_ATTACKED
  PLAYER_DIED
  ENEMY_DIED
  ITEM_PICKED
  LEVEL_UP
}