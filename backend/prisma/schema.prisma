// .prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- MODELO DE USUARIOS (Autenticación y Perfiles) ---
model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  name     String
  role     String?  @default("USER")

  scores   Score[]
}

// --- MODELO DE MAPAS (Instancias de escenario JSON) ---
model Map {
  id         Int      @id @default(autoincrement())
  name       String   // Ej: "Mazmorra de Inicio"
  level      Int      @default(1)
  
  layout     Json     
  dictionary Json     
  
  createdAt  DateTime @default(now())
}

// --- PUNTUACIONES GLOBALES E HISTORIAL ---
model Score {
  id                Int      @id @default(autoincrement())
  totalDamageDealt  Int      @default(0)
  totalDamageTaken  Int      @default(0)
  floor             Int      @default(1)
  kills             Int      @default(0)
  xp                Int      @default(0)
  
  userId            Int
  user              User     @relation(fields: [userId], references: [id])
  
  createdAt         DateTime @default(now())
}

// --- REGISTRO DE LOOT E INVENTARIO ---
model Item {
  id           Int      @id @default(autoincrement())
  name         String
  spriteKey    String
  description  String
  rarity       String   // "common", "uncommon", "rare"
  effects      Json     // Guardaremos algo como: [{"type": "heal", "value": 30}]
  
  isConsumable Boolean  @default(false)
  createdAt    DateTime @default(now())
}